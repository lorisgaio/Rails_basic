<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Doable" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Doable">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#FAF5E6] min-h-screen">
    <header class="border-b border-stone-200/60 bg-[#FAF5E6]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-14 items-center justify-between">
          <div class="flex-shrink-0">
            <%= link_to "Doable", root_path, class: "text-xl font-bold tracking-tight text-indigo-700" %>
          </div>
          <nav class="flex space-x-6">
            <%= link_to "Projects", projects_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
            <%= link_to "Todos", todos_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
          </nav>
        </div>
      </div>
    </header>

    <% if flash.any? %>
      <!-- Envolvemos também as mensagens flash no limite de largura -->
      <div class="max-w-4xl mx-auto px-4 mt-4">
        <% flash.each do |type, message| %>
          <div class="flash-<%= type %>">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Envolvemos o conteúdo principal em um container centralizado e limitado -->
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
